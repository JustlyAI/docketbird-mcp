# Copy to .env and fill in the values you need.

# --- stdio transport (local dev / Claude Desktop / Cursor) ---
# The DocketBird API key used for all requests when running without OAuth.
DOCKETBIRD_API_KEY=your_api_key_here

# --- http transport (remote server with OAuth) ---
# Public base URL of this server. Must match the URL clients connect to, since
# it is used as the OAuth issuer/resource URL and to build redirect links.
# Defaults to http://localhost:8080 when unset.
SERVER_URL=https://app.docketbird-mcp.com

# Directory for the SQLite auth database (users, OAuth clients, tokens).
# Defaults to ./data when unset. In Docker this is a mounted volume.
DATA_DIR=./data

# --- server-to-server (optional, http transport) ---
# When BOTH are set, a non-expiring bearer token is seeded at startup so a
# trusted headless client can call /mcp directly without OAuth.
# SERVICE_TOKEN=generate_a_long_random_string
# SERVICE_DOCKETBIRD_API_KEY=the_docketbird_key_the_service_identity_uses
